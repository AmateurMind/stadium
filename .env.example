# Google Cloud / Vertex AI Settings
PROJECT_ID=your-gcp-project-id
REGION=us-central1

# Google AI Studio Gemini API Key (Alternative for vertex ai)
GEMINI_API_KEY=

# Feature Flags (Set to false to run offline without credentials)
USE_GEMINI=true
USE_FIRESTORE=false
USE_BIGQUERY=false
USE_PUBSUB=false

# Application Settings
ENVIRONMENT=development
LOG_LEVEL=INFO
MAX_CHAT_HISTORY=50
GEMINI_MODEL=gemini-2.0-flash
THE_STATS_API_KEY=
