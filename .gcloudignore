# .gcloudignore - Configure files uploaded to Cloud Build

# Ignore git, venv, and node modules
.git/
.venv/
venv/
node_modules/
frontend/dist/
frontend/coverage/
backend/__pycache__/
backend/*.pyc
backend/.pytest_cache/
backend/.coverage
backend/htmlcov/
.DS_Store

# Keep required JSON configurations and datasets
!backend/data/grounds.json
!firebase.json
!frontend/package.json
!frontend/package-lock.json
!frontend/.eslintrc.json
!frontend/tsconfig.json
!frontend/tsconfig.node.json
